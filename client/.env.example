# Mapbox API Key (Required)
VITE_MAPBOX_API_KEY=your_mapbox_api_key_here

# API URL (Leave empty for localhost - uses Vite proxy)
# For production, set to your backend URL: https://your-backend.onrender.com
# VITE_API_URL=

# Socket URL (Leave empty for localhost - auto-detects http://localhost:5000)
# For production, set to your backend URL: https://your-backend.onrender.com
# VITE_SOCKET_URL=

# HOW IT WORKS:
# - Local Development: Leave VITE_SOCKET_URL empty → auto-uses http://localhost:5000
# - Production Build: Set VITE_SOCKET_URL=https://your-backend.onrender.com
# - Or use .env.production file for production defaults
