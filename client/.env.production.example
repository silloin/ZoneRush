# Production Environment Variables for Vercel Deployment
# Copy this to .env.production and update with your actual values

# Backend API URL (Render backend)
VITE_API_URL=https://your-backend.onrender.com/api

# Socket.IO URL (Render backend - without /api)
VITE_SOCKET_URL=https://your-backend.onrender.com

# Mapbox API Key (required)
VITE_MAPBOX_API_KEY=your_mapbox_api_key_here

# Optional: Firebase configuration for push notifications
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
