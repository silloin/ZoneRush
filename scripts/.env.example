# ============================================
# Database Scripts Environment Variables
# ============================================
# ⚠️  NEVER commit this file!
# 📝 Used by .bat and .js scripts for database operations
# 🔒 Keep this file secure and out of version control

# ============================================
# Database Connection
# ============================================
# Local Development Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_your_database_password
DB_NAME=zonerush

# For production, use connection string:
# DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# Usage in Batch Scripts (.bat)
# ============================================
# Set PGPASSWORD for psql commands
PGPASSWORD=%DB_PASSWORD%

# ============================================
# Usage in Node.js Scripts (.js)
# ============================================
# Access via: process.env.DB_PASSWORD
# Example:
#   const pool = new Pool({
#     host: process.env.DB_HOST,
#     port: process.env.DB_PORT,
#     user: process.env.DB_USER,
#     password: process.env.DB_PASSWORD,
#     database: process.env.DB_NAME
#   });

# ============================================
# Security Notes
# ============================================
# 1. Never use default passwords like "8810" or "password"
# 2. Use strong passwords (16+ chars, mixed case + numbers + symbols)
# 3. Rotate database password periodically
# 4. Use different passwords for dev/staging/production
# 5. Never share this file or commit to git
