# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
DATABASE_URL=postgres://user:password@localhost:5432/zonerush

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_URL=http://localhost:5000/api
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ============================================
# EMAIL CONFIGURATION (REQUIRED FOR SOS ALERTS)
# ============================================
# Using Gmail: Create an App Password (not your regular password)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select Mail and Windows Computer
# 3. Copy the 16-character password and paste below
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password
EMAIL_PASS=your-16-char-app-password
EMAIL_SERVICE=gmail

# Alternative: Using custom SMTP
# SMTP_HOST=smtp.yourserver.com
# SMTP_PORT=587
# SMTP_USER=your-email@yourserver.com
# SMTP_PASS=your-password

# ============================================
# SMS CONFIGURATION (FOR SOS ALERTS)
# ============================================
# TextLocal API for SMS alerts
TEXTLOCAL_API_KEY=your_textlocal_api_key
TEXTLOCAL_SENDER=ZONERUSH

# Twilio (alternative to TextLocal)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# SECURITY (JWT & SESSIONS)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-prod
SESSION_SECRET=your-session-secret-change-this-in-prod

# ============================================
# AUTHENTICATION  
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================
# PUSH NOTIFICATIONS (FIREBASE)
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=debug

# ============================================
# DEPLOYMENT
# ============================================
RENDER_API_KEY=your_render_api_key_for_deployment
