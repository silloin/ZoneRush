# Production Environment Variables Template for Backend (Render)
# Copy this file and rename to .env.production
# Then fill in your actual values

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production
PORT=10000

# ============================================
# DATABASE (Supabase)
# ============================================
# Get from Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres

# ============================================
# AUTHENTICATION
# ============================================
# Generate a secure random string (minimum 32 characters)
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_here_minimum_32_characters_random

# ============================================
# CORS CONFIGURATION
# ============================================
# Your Vercel frontend URL (no trailing slash)
# Example: https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# ============================================
# EXTERNAL API KEYS
# ============================================

# Weather API (OpenWeatherMap)
# Get from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key

# Air Quality API (WAQI)
# Get from: https://aqicn.org/data-platform/token/
AQI_API_KEY=your_waqi_api_key

# Groq AI (for AI Coach)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Choose one email service: resend, mailjet, sendgrid, mailgun
EMAIL_SERVICE=resend

# Resend (Recommended)
# Get from: https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Mailjet (Alternative)
# Get from: https://www.mailjet.com/
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key

# SendGrid (Alternative)
# Get from: https://sendgrid.com/
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=verified@yourdomain.com

# Mailgun (Alternative)
# Get from: https://www.mailgun.com/
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@mg.yourdomain.com

# ============================================
# SMS CONFIGURATION (Optional - for SOS alerts)
# ============================================

# Twilio
# Get from: https://www.twilio.com/
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# TextLocal (India)
# Get from: https://www.textlocal.in/
TEXTLOCAL_API_KEY=your_textlocal_api_key
TEXTLOCAL_SENDER=ZONERUSH

# ============================================
# MAPBOX (Optional for backend)
# ============================================
MAPBOX_API_KEY=pk.your_mapbox_token

# ============================================
# BCRYPT CONFIGURATION
# ============================================
BCRYPT_SALT_ROUNDS=12

# ============================================
# NOTES FOR RENDER DEPLOYMENT
# ============================================
# 1. Add these environment variables in Render Dashboard
# 2. Go to: Service → Environment
# 3. Add each variable
# 4. For sensitive values, use "Secret" type
# 5. Redeploy after adding variables
# 
# IMPORTANT:
# - Never commit this file with real values to Git
# - Keep your .env files secure
# - Rotate API keys regularly
# - Use different JWT_SECRET for production
