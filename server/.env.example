# PostgreSQL Connection (Local)
DB_USER=postgres
DB_PASSWORD=8810
DB_HOST=localhost
DB_DATABASE=zonerush
DB_PORT=5432

# PostgreSQL Connection (Production - Render/Railway)
# DATABASE_URL=postgresql://user:password@host:5432/zonerush

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Test User (for create-test-user.js only)
TEST_USER_EMAIL=test@example.com
TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=changeme123
BCRYPT_SALT_ROUNDS=12

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_weather_api_key_here

# Air Quality API (WAQI - aqicn.org)
AQI_API_KEY=your_aqi_api_key_here

# Groq AI API
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration
# Option 1: Gmail (requires 2-Step Verification + App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_password

# Option 2: Resend (recommended for production)
# EMAIL_SERVICE=resend
# EMAIL_USER=your_verified_email@yourdomain.com
# RESEND_API_KEY=re_your_resend_api_key

# Option 3: Ethereal Email (for testing - no setup needed)
# EMAIL_SERVICE=ethereal

# SMS Configuration - TextLocal (India)
# Get API Key from: https://www.textlocal.in/
TEXTLOCAL_API_KEY=your_textlocal_api_key_here
TEXTLOCAL_SENDER=ZONERUSH

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Mapbox API (for server-side geocoding if needed)
MAPBOX_API_KEY=your_mapbox_api_key_here

# Firebase (for push notifications - optional)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_PRIVATE_KEY=your_private_key
# FIREBASE_CLIENT_EMAIL=your_client_email
